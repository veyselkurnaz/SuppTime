---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page Not Found - SuppTime" description="Page not found." lang="en" dir="ltr">
  <main style="padding-top: 120px; min-height: 80vh; display: flex; align-items: center; justify-content: center; text-align: center;">
    <div style="padding: 40px;">
      <div style="font-size: 80px; font-weight: 800; color: var(--emerald); margin-bottom: 16px; line-height: 1;">404</div>
      <h1 id="title404" style="font-size: 32px; font-weight: 700; margin-bottom: 16px; color: var(--ink);">Oops! Page Not Found</h1>
      <p id="desc404" style="font-size: 18px; color: var(--ink-soft); margin-bottom: 32px; max-width: 400px; margin-left: auto; margin-right: auto;">Looks like you took the wrong pill. We couldn't find this page, but don't forget your vitamins!</p>
      
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a id="home404" href="/" class="btn" style="background: var(--bg-2); color: var(--ink); border: 1px solid var(--line); padding: 14px 28px; border-radius: 99px; text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 8px;">
          <span>Back to Home</span>
        </a>
        <a id="dl404" href="https://apps.apple.com/app/supptime-vitamin-tracker/id6762088156" class="btn btn-primary" style="padding: 14px 28px; border-radius: 99px; text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 8px;">
          <svg viewBox="0 0 384 512" style="width: 16px; height: 16px;" preserveAspectRatio="xMidYMid meet" fill="currentColor"><path d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z" /></svg>
          <span>Download App</span>
        </a>
      </div>
    </div>
  </main>
  
  <script is:inline>
    const langs = {
      en: { t: "Oops! Page Not Found", d: "Looks like you took the wrong pill. We couldn't find this page, but don't forget your vitamins!", h: "Back to Home", dl: "Download App" },
      tr: { t: "Oops! Sayfa Bulunamadı", d: "Galiba hapı yanlış saatte yuttunuz! Aradığınız sayfayı bulamadık ama vitaminlerinizi unutmayın.", h: "Ana Sayfaya Dön", dl: "Uygulamayı İndir" },
      de: { t: "Hoppla! Seite nicht gefunden", d: "Sieht aus, als hätten Sie die falsche Pille genommen. Wir konnten diese Seite nicht finden!", h: "Zurück zur Startseite", dl: "App herunterladen" },
      es: { t: "¡Vaya! Página no encontrada", d: "Parece que tomaste la pastilla equivocada. ¡No pudimos encontrar esta página!", h: "Volver al inicio", dl: "Descargar la App" },
      it: { t: "Ops! Pagina non trovata", d: "Sembra che tu abbia preso la pillola sbagliata. Non riusciamo a trovare questa pagina!", h: "Torna alla Home", dl: "Scarica l'App" },
      ja: { t: "おっと！ページが見つかりません", d: "間違った薬を飲んでしまったようです。このページは見つかりませんでした！", h: "ホームに戻る", dl: "アプリをダウンロード" },
      ko: { t: "앗! 페이지를 찾을 수 없습니다", d: "잘못된 약을 복용한 것 같습니다. 이 페이지를 찾을 수 없습니다!", h: "홈으로 돌아가기", dl: "앱 다운로드" },
      zh: { t: "哎呀！找不到页面", d: "看起来您吃错药了。我们找不到这个页面！", h: "返回主页", dl: "下载应用" },
      ru: { t: "Упс! Страница не найдена", d: "Похоже, вы приняли не ту таблетку. Мы не смогли найти эту страницу!", h: "На главную", dl: "Скачать приложение" }
    };
    
    try {
      const userLang = navigator.language.substring(0, 2).toLowerCase();
      const text = langs[userLang] || langs['en'];
      
      document.getElementById('title404').innerText = text.t;
      document.getElementById('desc404').innerText = text.d;
      document.getElementById('home404').querySelector('span').innerText = text.h;
      document.getElementById('dl404').querySelector('span').innerText = text.dl;
    } catch(e) {}
  </script>
</Layout>
