---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import { I18N } from '../../../i18n.js';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  return posts.map((post: CollectionEntry<'blog'>) => {
    // id is like "en/best-time-for-vitamin-d.md"
    const [lang, ...slugParts] = post.id.split('/');
    // slug is the filename without lang and without .md
    const slug = slugParts.join('/').replace(/\.md$/, '');
    
    return {
      params: { lang, slug },
      props: { post, allPosts: posts },
    };
  });
}

interface Props {
  post: CollectionEntry<'blog'>;
  allPosts: CollectionEntry<'blog'>[];
}

const { lang, slug } = Astro.params as { lang: string; slug: string };
const { post, allPosts } = Astro.props as Props;
const { Content } = await render(post);

const t = I18N[lang as keyof typeof I18N] || I18N['en'];

const localizedHashtags: Record<string, string> = {
  'tr': 'SuppTime,Sağlık,Vitamin,Beslenme,Zindelik,Takviye',
  'de': 'SuppTime,Gesundheit,Vitamine,Ernährung,Wohlbefinden,Nahrungsergänzung',
  'es': 'SuppTime,Salud,Vitaminas,Nutrición,Bienestar,Suplementos',
  'pt-br': 'SuppTime,Saúde,Vitaminas,Nutrição,BemEstar,Suplementos',
  'it': 'SuppTime,Salute,Vitamine,Nutrizione,Benessere,Integratori',
  'nl': 'SuppTime,Gezondheid,Vitaminen,Voeding,Welzijn,Supplementen',
  'pl': 'SuppTime,Zdrowie,Witaminy,Odżywianie,DobreSamopoczucie,Suplementy',
  'ru': 'SuppTime,Здоровье,Витамины,Питание,Самочувствие,Добавки',
  'ko': 'SuppTime,건강,비타민,영양,웰빙,영양제',
  'ja': 'SuppTime,健康,ビタミン,栄養,ウェルネス,サプリメント',
  'zh-cn': 'SuppTime,健康,维生素,营养,养生,保健品',
  'zh-tw': 'SuppTime,健康,維生素,營養,養生,保健品',
  'id': 'SuppTime,Kesehatan,Vitamin,Nutrisi,Kebugaran,Suplemen',
  'vi': 'SuppTime,SứcKhỏe,Vitamin,DinhDưỡng,ThểChất,ThựcPhẩmChứcNăng',
  'th': 'SuppTime,สุขภาพ,วิตามิน,โภชนาการ,ความเป็นอยู่ที่ดี,อาหารเสริม',
  'ar': 'SuppTime,صحة,فيتامينات,تغذية,عافية,مكملات_غذائية',
  'en': 'SuppTime,Health,Vitamins,Wellness,Nutrition,Supplements'
};
const xHashtags = encodeURI(localizedHashtags[lang] || localizedHashtags['en']);

// SEO: Find translations of this post for hreflang
const translations = allPosts.filter((p: CollectionEntry<'blog'>) => p.data.translationKey === post.data.translationKey);

const LANG_ORDER = ['en','tr','ko','ja','zh-cn','zh-tw','de','es','pt-br','it','nl','pl','ru','id','vi','th','ar'];

const wordCount = post.body ? post.body.split(/\s+/).length : 0;
// KaTeX CSS is ~800ms of render-blocking weight — only load it on posts that actually use math syntax.
const hasMath = post.body ? /\$\$[\s\S]+?\$\$|\$[^\s$][^$]*\$/.test(post.body) : false;

// Grab related posts — prioritize the pillar guide and same-cluster topics over
// pure randomness, so posts actually link to each other instead of being orphans.
const PILLAR_KEY = 'supplement-timing-complete-guide';
const CLUSTERS: Record<string, string> = {
  'iron-supplement-guide': 'minerals',
  'calcium-supplement-guide': 'minerals',
  'zinc-supplement-guide': 'minerals',
  'supplement-interactions': 'minerals',
  'vitamin-d-timing': 'absorption',
  'best-time-for-vitamin-b12': 'absorption',
  'omega-3-supplement-guide': 'absorption',
  'magnesium-forms-guide': 'form',
  'collagen-usage-guide': 'form',
};
const myCluster = CLUSTERS[post.data.translationKey];
const otherPostsInLang = allPosts.filter((p: CollectionEntry<'blog'>) => p.id.startsWith(`${lang}/`) && p.id !== post.id);
const pillarPost = post.data.translationKey !== PILLAR_KEY
  ? otherPostsInLang.find((p: CollectionEntry<'blog'>) => p.data.translationKey === PILLAR_KEY)
  : undefined;
const sameClusterPosts = otherPostsInLang
  .filter((p: CollectionEntry<'blog'>) => p.data.translationKey !== PILLAR_KEY && myCluster && CLUSTERS[p.data.translationKey] === myCluster)
  .sort(() => 0.5 - Math.random());
const fillerPosts = otherPostsInLang
  .filter((p: CollectionEntry<'blog'>) => p.data.translationKey !== PILLAR_KEY && !(myCluster && CLUSTERS[p.data.translationKey] === myCluster))
  .sort(() => 0.5 - Math.random());
const prioritized = [...(pillarPost ? [pillarPost] : []), ...sameClusterPosts, ...fillerPosts];
const relatedPosts = prioritized.slice(0, 3).map(rp => ({
  ...rp,
  rpSlug: rp.id.split('/').pop()?.replace('.md', '')
}));
const relatedTitle = {
  'tr': 'İlgili Makaleler',
  'de': 'Ähnliche Artikel',
  'es': 'Artículos Relacionados',
  'pt-br': 'Artigos Relacionados',
  'ru': 'Похожие статьи',
  'zh-cn': '相关文章',
  'ko': '관련 기사',
  'ja': '関連記事'
}[lang] || 'Related Articles';

// Generate JSON-LD Schema
const schema = [
  {
    "@context": "https://schema.org",
    "@type": ["Article", "MedicalWebPage"],
    "headline": post.data.title,
    "description": post.data.description,
    "author": {
      "@type": "Person",
      "name": post.data.author || "SuppTime Editorial",
      "url": "https://supptime.app/"
    },
    "publisher": {
      "@id": "https://supptime.app/#organization"
    },
    "image": post.data.image ? `https://supptime.app${post.data.image}` : undefined,
    "datePublished": post.data.pubDate.toISOString(),
    "dateModified": post.data.pubDate.toISOString(),
    "inLanguage": lang,
    "wordCount": wordCount,
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://supptime.app/${lang}/blog/${slug}`
    }
  }
  // Note: the site's single SoftwareApplication + Organization entities are declared
  // once, sitewide, in Layout.astro — no need to repeat a conflicting copy per post.
];

const slugLinks: Record<string, string> = {};
const alternateUrls: Record<string, string> = {};

LANG_ORDER.forEach(code => {
  const translation = translations.find((p: CollectionEntry<'blog'>) => p.id.startsWith(`${code}/`));
  if (translation) {
    const translatedPath = `/${code}/blog/${translation.id.split('/').pop()?.replace('.md', '')}/`;
    slugLinks[code] = translatedPath;
    alternateUrls[code] = translatedPath;
  } else {
    slugLinks[code] = `/${code}/blog/`;
  }
});

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "SuppTime",
      "item": "https://supptime.app/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": `https://supptime.app/${lang}/blog/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": post.data.title,
      "item": `https://supptime.app/${lang}/blog/${slug}/`
    }
  ]
};
schema.push(breadcrumbSchema as any);

// FAQPage schema — only emitted when the post has real faq entries, and the
// same Q&A is rendered visibly on the page below (schema must match visible content).
if (post.data.faq && post.data.faq.length > 0) {
  schema.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": post.data.faq.map((item: { q: string; a: string }) => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": { "@type": "Answer", "text": item.a }
    }))
  } as any);
}
---

<Layout title={`${post.data.title} - SuppTime`} description={post.data.description} lang={lang} dir={t.dir || 'ltr'} image={post.data.image} ogType="article" alternateUrls={alternateUrls} pubDate={post.data.pubDate} author={post.data.author} hasMath={hasMath}>
  <!-- Inject JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
  
  <Navbar lang={lang} isBlog={true} slugLinks={slugLinks} />

  <main style="padding-top: 120px; min-height: 100vh; background: #fafafa; padding-bottom: 120px;">
    <div style="max-width: 760px; margin: 0 auto 24px auto;">
      <a href={`/${lang}/blog`} style="display: inline-flex; align-items: center; gap: 8px; color: #666; text-decoration: none; font-weight: 500; font-size: 15px; transition: color 0.2s;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        {lang === 'tr' ? 'Bloga Dön' : 'Back to Blog'}
      </a>
    </div>
    <article style="max-width: 760px; margin: 0 auto; padding: 48px; background: white; border-radius: 24px; box-shadow: 0 8px 30px rgba(0,0,0,0.04);">
      {post.data.image && (
        <div style="margin: -48px -48px 40px -48px; border-radius: 24px 24px 0 0; overflow: hidden; background: #f4f6f8; text-align: center; position: relative;">
          <img src={post.data.image} alt={post.data.title} style="width: 100%; height: auto; aspect-ratio: 16/9; object-fit: cover; object-position: center; display: block;" />
          <div style="position: absolute; bottom: 20px; right: 20px; display: flex; align-items: center; gap: 8px; background: rgba(255, 255, 255, 0.9); padding: 6px 14px; border-radius: 99px; box-shadow: 0 8px 24px rgba(0,0,0,0.15); backdrop-filter: blur(12px);">
            <img src="/assets/watchos.png" alt="SuppTime Logo" style="width: 18px; height: 18px; border-radius: 4px;" />
            <span style="font-weight: 700; font-size: 13px; color: #111; letter-spacing: -0.02em;">SuppTime</span>
          </div>
        </div>
      )}
      <h1 style="font-size: 38px; font-weight: 700; margin-bottom: 20px; line-height: 1.25; letter-spacing: -0.02em;">{post.data.title}</h1>
      <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 48px; flex-wrap: wrap; gap: 24px;">
        <div>
          <div style="color: #666; margin-bottom: 16px; font-size: 15px; font-weight: 500;">
            <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString(lang)}</time> • {post.data.author || 'SuppTime Team'}
          </div>
        </div>
        
        <div style="display: flex; align-items: center; gap: 8px;">
          <span style="font-size: 14px; font-weight: 600; color: #888; margin-right: 8px;">{lang === 'tr' ? 'Paylaş' : (lang === 'de' ? 'Teilen' : (lang === 'es' ? 'Compartir' : (lang === 'pt-br' ? 'Compartilhar' : (lang === 'it' ? 'Condividi' : (lang === 'nl' ? 'Delen' : (lang === 'pl' ? 'Udostępnij' : (lang === 'ru' ? 'Поделиться' : (lang === 'ko' ? '공유하기' : (lang === 'ja' ? '共有' : (lang === 'zh-cn' ? '分享' : (lang === 'zh-tw' ? '分享' : 'Share')))))))))))}</span>
          <a href={`https://x.com/intent/tweet?url=https://supptime.app/${lang}/blog/${slug}&text=${encodeURIComponent(post.data.title)}&hashtags=${xHashtags}`} target="_blank" rel="noopener noreferrer" class="share-btn x-btn" aria-label="Share on X">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.005 4.15H5.059z"/></svg>
          </a>
          <a href={`https://api.whatsapp.com/send?text=${encodeURIComponent(post.data.title)}%20https://supptime.app/${lang}/blog/${slug}`} target="_blank" rel="noopener noreferrer" class="share-btn wa-btn" aria-label="Share on WhatsApp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          </a>
          <a href={`https://www.linkedin.com/sharing/share-offsite/?url=https://supptime.app/${lang}/blog/${slug}`} target="_blank" rel="noopener noreferrer" class="share-btn in-btn" aria-label="Share on LinkedIn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=https://supptime.app/${lang}/blog/${slug}`} target="_blank" rel="noopener noreferrer" class="share-btn fb-btn" aria-label="Share on Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={`https://line.me/R/msg/text/?${encodeURIComponent(post.data.title)}%20https://supptime.app/${lang}/blog/${slug}`} target="_blank" rel="noopener noreferrer" class="share-btn line-btn" aria-label="Share on LINE">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 10.304c0-5.369-5.383-9.738-12-9.738-6.616 0-12 4.369-12 9.738 0 4.814 4.269 8.846 10.036 9.608.391.084.922.258 1.057.592.122.303.079.778.039 1.085l-.171 1.027c-.053.303-.242 1.186 1.039.647 1.281-.54 6.911-4.069 9.428-6.967 1.739-1.907 2.572-3.843 2.572-5.992zm-18.988-2.595h2.408c.316 0 .573.257.573.573v.842c0 .316-.257.573-.573.573h-1.26v1.26h1.26c.316 0 .573.257.573.573v.842c0 .316-.257.573-.573.573h-2.408c-.316 0-.573-.257-.573-.573v-4.091c0-.316.257-.572.573-.572zm5.82 4.091c0 .316-.257.573-.573.573h-.842c-.316 0-.573-.257-.573-.573v-4.091c0-.316.257-.572.573-.572h.842c.316 0 .573.256.573.572v4.091zm4.492-4.091h.842c.316 0 .573.256.573.572v4.091c0 .316-.257.573-.573.573h-.842c-.316 0-.573-.257-.573-.573v-4.091c0-.316.257-.572.573-.572zm4.33 4.091c0 .316-.257.573-.573.573h-2.408c-.316 0-.573-.257-.573-.573v-4.091c0-.316.257-.572.573-.572h2.408c.316 0 .573.256.573.572v.842c0 .316-.257.573-.573.573h-1.26v1.26h1.26c.316 0 .573.257.573.573v.842z"/></svg>
          </a>
          <a href={`https://story.kakao.com/share?url=https://supptime.app/${lang}/blog/${slug}`} target="_blank" rel="noopener noreferrer" class="share-btn kakao-btn" aria-label="Share on KakaoTalk">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3c-5.836 0-10.564 3.738-10.564 8.354 0 3.014 1.954 5.671 4.935 7.086L5.3 21.687c-.12.441.341.77.712.502l3.856-2.793c.692.124 1.405.187 2.132.187 5.836 0 10.564-3.738 10.564-8.354C22.564 6.738 17.836 3 12 3z"/></svg>
          </a>
          <a href="javascript:void(0)" onclick={`navigator.clipboard.writeText('https://supptime.app/${lang}/blog/${slug}'); alert('Link copied to clipboard. Open WeChat to share.');`} class="share-btn wechat-btn" aria-label="Share on WeChat">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.07 12.82c-.52 0-1.02-.05-1.5-.16a6.6 6.6 0 01-.19-.77c0-3.62-3.48-6.55-7.77-6.55S-.16 8.27-.16 11.89c0 2.05 1.13 3.87 2.87 5.12l-1.04 3.08 3.51-1.8c.8.23 1.66.36 2.55.36.46 0 .9-.05 1.34-.13a5.53 5.53 0 008 2.21l2.58 1.32-.76-2.27c1.33-.97 2.18-2.41 2.18-4.04 0-2.85-2.61-5.16-5.83-5.16zm-10.6-2.18c.45 0 .82.37.82.82s-.37.82-.82.82-.82-.37-.82-.82.37-.82.82-.82zm4.1 1.64c-.45 0-.82-.37-.82-.82s.37-.82.82-.82.82.37.82.82-.37.82-.82.82zm6.55 3.55c-.32 0-.58-.26-.58-.58s.26-.58.58-.58.58.26.58.58-.26.58-.58.58zm-2.73 0c-.32 0-.58-.26-.58-.58s.26-.58.58-.58.58.26.58.58-.26.58-.58.58z" transform="translate(.16 -5.34)"/></svg>
          </a>
        </div>
      </div>
      
      <div class="prose" style="font-size: 18px; line-height: 1.7; color: #333;">
        <Content />
      </div>

      {post.data.faq && post.data.faq.length > 0 && (
        <div class="blog-faq" style="margin-top: 48px; border-top: 1px solid #eee; padding-top: 48px;">
          <h2 style="font-size: 24px; font-weight: 700; margin-bottom: 24px; letter-spacing: -0.01em;">{t.faq.title}</h2>
          <div style="display: flex; flex-direction: column; gap: 20px;">
            {post.data.faq.map((item: { q: string; a: string }) => (
              <div>
                <h3 style="font-size: 17px; font-weight: 600; margin-bottom: 8px; color: #111;">{item.q}</h3>
                <p style="font-size: 15px; line-height: 1.65; color: #444; margin: 0;">{item.a}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      <div class="blog-disclaimer" style="margin-top: 48px; padding: 20px; background: #f4f6f8; border-radius: 12px; font-size: 13px; line-height: 1.6; color: #666; border: 1px solid #e2e8f0; font-family: var(--sans);">
        {t.blog_disclaimer}
      </div>
      
      <div style="margin-top: 48px; border-top: 1px solid #eee; padding-top: 48px; display: flex; justify-content: center;">
          <div class="dl-ctas">
              <a href="https://apps.apple.com/app/supptime-vitamin-tracker/id6762088156"
                  class="as-btn">
                  <span class="as-btn-glyph">
                      <svg viewBox="0 0 384 512" style="width: 28px; height: 32px;"
                          preserveAspectRatio="xMidYMid meet" fill="currentColor">
                          <path
                              d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z" />
                      </svg>
                  </span>
                  <span class="as-btn-text">
                      <span class="as-btn-top">{t.cta.appstore_top}</span>
                      <span class="as-btn-bottom">{t.cta.appstore_bottom}</span>
                  </span>
              </a>
          </div>
      </div>
      
      {relatedPosts.length > 0 && (
        <div style="margin-top: 64px; border-top: 1px solid #eee; padding-top: 48px;">
          <h3 style="font-size: 24px; font-weight: 700; margin-bottom: 24px; letter-spacing: -0.01em;">{relatedTitle}</h3>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 24px;">
            {relatedPosts.map((rp: any) => (
              <a href={`/${lang}/blog/${rp.rpSlug}`} class="related-card" style="text-decoration: none; color: inherit; display: block; border-radius: 16px; overflow: hidden; background: #fafafa; border: 1px solid #eee; transition: transform 0.2s, box-shadow 0.2s;">
                {rp.data.image && <img src={rp.data.image} alt={rp.data.title} loading="lazy" style="width: 100%; height: 140px; object-fit: cover; display: block;" />}
                <div style="padding: 16px;">
                  <h4 style="font-size: 16px; font-weight: 600; margin: 0; line-height: 1.4; color: #111;">{rp.data.title}</h4>
                </div>
              </a>
            ))}
          </div>
          <style>
            .related-card:hover {
              transform: translateY(-4px);
              box-shadow: 0 12px 24px rgba(0,0,0,0.06);
            }
          </style>
        </div>
      )}
    </article>
  </main>
  
  <script type="module" is:inline>
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';
    mermaid.initialize({ 
      startOnLoad: false, 
      theme: 'base', 
      securityLevel: 'loose',
      flowchart: { htmlLabels: true, nodeSpacing: 40, rankSpacing: 40, padding: 15 },
      themeVariables: { 
        fontFamily: 'system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif', 
        primaryColor: '#f4f9ff', 
        primaryBorderColor: '#cce3f6', 
        primaryTextColor: '#111', 
        lineColor: '#007aff',
        fontSize: '14px'
      } 
    });
    
    document.addEventListener('DOMContentLoaded', async () => {
      const blocks = document.querySelectorAll('pre[data-language="mermaid"], pre.language-mermaid');
      if (blocks.length === 0) return;
      
      blocks.forEach((block, index) => {
        const code = block.textContent;
        const div = document.createElement('div');
        div.className = 'mermaid';
        div.id = 'mermaid-chart-' + index;
        div.style.display = 'flex';
        div.style.justifyContent = 'center';
        div.style.margin = '40px 0';
        div.textContent = code;
        block.parentNode.replaceChild(div, block);
      });
      
      try {
        await mermaid.run({ nodes: document.querySelectorAll('.mermaid') });
      } catch (err) {
        console.error('Mermaid render error:', err);
      }
    });
  </script>
  <script>
    // GitHub Alerts Parser
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.prose blockquote').forEach(bq => {
        const html = bq.innerHTML;
        if (html.includes('[!TIP]')) {
          const content = html.replace(/\[!TIP\](?:<br>|\n)?/i, '');
          bq.innerHTML = `<div class="alert-icon">💡</div><div>${content}</div>`;
          bq.classList.add('alert-tip');
        } else if (html.includes('[!WARNING]') || html.includes('[!CAUTION]')) {
          const content = html.replace(/\[!(?:WARNING|CAUTION)\](?:<br>|\n)?/i, '');
          bq.innerHTML = `<div class="alert-icon">⚠️</div><div>${content}</div>`;
          bq.classList.add('alert-warning');
        }
      });
    });

    // Language Menu Toggling
    const langBtn = document.getElementById('lang-btn');
    const langMenu = document.getElementById('lang-menu');
    let langMenuOpen = false;
    
    if (langBtn && langMenu) {
      langBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        langMenuOpen = !langMenuOpen;
        langMenu.style.display = langMenuOpen ? 'grid' : 'none';
      });
      document.addEventListener('mousedown', (e) => {
        if (langMenuOpen && e.target instanceof Node && !langBtn.contains(e.target) && !langMenu.contains(e.target)) {
          langMenuOpen = false;
          langMenu.style.display = 'none';
        }
      });
    }
  </script>
</Layout>

