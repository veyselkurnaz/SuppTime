---
import { getCollection, render } from 'astro:content';
import { I18N } from '../../../i18n.js';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  return posts.map(post => {
    // id is like "en/best-time-for-vitamin-d.md"
    const [lang, ...slugParts] = post.id.split('/');
    // slug is the filename without lang and without .md
    const slug = slugParts.join('/').replace(/\.md$/, '');
    
    return {
      params: { lang, slug },
      props: { post, allPosts: posts },
    };
  });
}

const { lang } = Astro.params;
const { post, allPosts } = Astro.props;
const { Content } = await render(post);

const t = I18N[lang];

// SEO: Find translations of this post for hreflang
const translations = allPosts.filter(p => p.data.translationKey === post.data.translationKey);

const LANG_ORDER = ['en','tr','ko','ja','zh-cn','zh-tw','de','es','pt-br','it','nl','pl','ru','id','vi','th','ar'];

function shortCode(c) { 
  if (c === 'pt-br') return 'PT';
  if (c === 'zh-cn') return '简';
  if (c === 'zh-tw') return '繁';
  return c.toUpperCase(); 
}

// Generate JSON-LD Schema
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "author": {
      "@type": "Organization",
      "name": post.data.author
    },
    "datePublished": post.data.pubDate.toISOString(),
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://supptime.app/${lang}/blog/${Astro.params.slug}`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "SuppTime",
    "operatingSystem": "iOS",
    "applicationCategory": "HealthAndFitnessApplication",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "url": "https://apps.apple.com/app/supptime-vitamin-tracker/id6762088156"
  }
];

---

<Layout title={`${post.data.title} - SuppTime`} description={post.data.description} lang={lang} dir={t.dir || 'ltr'} image="/blog/vitamin_d_blog_cover.png" ogType="article">
  <!-- Inject JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  
  <nav class="nav" id="nav" style="background: rgba(255,255,255,0.8); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(0,0,0,0.05);">
      <div class="nav-inner">
          <a href={`/${lang}/`} class="brand">
              <span class="brand-mark" style="width: 32px; height: 32px;">
                  <img src="/assets/watchos.png" alt="SuppTime" />
              </span>
              <span class="brand-name">SuppTime</span>
          </a>
          <div class="nav-links">
              <a href={`/${lang}/`}>{t.nav.home}</a>
              <a href={`/${lang}/blog/`}>{t.nav.blog}</a>
          </div>
          <div class="nav-tools">
              <div style="position: relative;" id="lang-switcher">
                  <button class="lang-btn" id="lang-btn" aria-label="Language">
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="10" />
                          <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                      </svg>
                      <span style="font-weight: 600" id="current-lang-code">{shortCode(lang)}</span>
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="m6 9 6 6 6-6" />
                      </svg>
                  </button>
                  <div class="lang-menu lang-menu-tall" id="lang-menu" style="display: none;">
                    {LANG_ORDER.map(code => {
                      const opt = I18N[code];
                      const translation = translations.find(p => p.id.startsWith(`${code}/`));
                      const link = translation ? `/${code}/blog/${translation.id.split('/').pop().replace('.md', '')}` : `/${code}/blog/`;
                      return (
                        <a href={link} class={`lang-opt ${code === lang ? 'is-active' : ''}`} style="text-decoration:none; color:inherit;">
                          <span style="font-family: var(--mono); font-size: 11px; opacity: 0.5; width: 26px;">{shortCode(code)}</span>
                          <span>{opt.langName}</span>
                          {code === lang && (
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
                          )}
                        </a>
                      );
                    })}
                  </div>
              </div>
          </div>
      </div>
  </nav>

  <main style="padding-top: 120px; min-height: 100vh; background: #fafafa;">
    <article style="max-width: 700px; margin: 0 auto; padding: 48px 24px; background: white; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.03);">
      <h1 style="font-size: 36px; font-weight: 700; margin-bottom: 16px; line-height: 1.2;">{post.data.title}</h1>
      <div style="color: #666; margin-bottom: 48px; font-size: 15px; border-bottom: 1px solid #eee; padding-bottom: 24px;">
        {post.data.pubDate.toLocaleDateString(lang)} • {post.data.author}
      </div>
      
      <div class="prose" style="font-size: 18px; line-height: 1.7; color: #333;">
        <Content />
      </div>

      <div class="blog-disclaimer" style="margin-top: 48px; padding: 20px; background: #f4f6f8; border-radius: 12px; font-size: 13px; line-height: 1.6; color: #666; border: 1px solid #e2e8f0; font-family: var(--sans);">
        {t.blog_disclaimer}
      </div>
      
      <div style="margin-top: 48px; border-top: 1px solid #eee; padding-top: 48px; display: flex; justify-content: center;">
          <div class="dl-ctas">
              <a href="https://apps.apple.com/app/supptime-vitamin-tracker/id6762088156"
                  class="as-btn">
                  <span class="as-btn-glyph">
                      <svg viewBox="0 0 384 512" style="width: 28px; height: 32px;"
                          preserveAspectRatio="xMidYMid meet" fill="currentColor">
                          <path
                              d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7C63.3 141.2 4 184.8 4 273.5q0 39.3 14.4 81.2c12.8 36.7 59 126.7 107.2 125.2 25.2-.6 43-17.9 75.8-17.9 31.8 0 48.3 17.9 76.4 17.9 48.6-.7 90.4-82.5 102.6-119.3-65.2-30.7-61.7-90-61.7-91.9zm-56.6-164.2c27.3-32.4 24.8-61.9 24-72.5-24.1 1.4-52 16.4-67.9 34.9-17.5 19.8-27.8 44.3-25.6 71.9 26.1 2 49.9-11.4 69.5-34.3z" />
                      </svg>
                  </span>
                  <span class="as-btn-text">
                      <span class="as-btn-top">{t.cta.appstore_top}</span>
                      <span class="as-btn-bottom">{t.cta.appstore_bottom}</span>
                  </span>
              </a>
          </div>
      </div>
    </article>
  </main>
  
  <script>
    // Language Menu Toggling
    const langBtn = document.getElementById('lang-btn');
    const langMenu = document.getElementById('lang-menu');
    let langMenuOpen = false;
    
    if (langBtn && langMenu) {
      langBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        langMenuOpen = !langMenuOpen;
        langMenu.style.display = langMenuOpen ? 'grid' : 'none';
      });
      document.addEventListener('mousedown', (e) => {
        if (langMenuOpen && !langBtn.contains(e.target) && !langMenu.contains(e.target)) {
          langMenuOpen = false;
          langMenu.style.display = 'none';
        }
      });
    }
  </script>
</Layout>

<style is:global>
  .prose h1 {
    display: none;
  }
  .prose h2 {
    font-size: 24px;
    font-weight: 600;
    margin-top: 40px;
    margin-bottom: 16px;
  }
  .prose p {
    margin-bottom: 24px;
  }
  .prose strong {
    font-weight: 600;
    color: #111;
  }
</style>
