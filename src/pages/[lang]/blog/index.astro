---
import { getCollection } from 'astro:content';
import { I18N } from '../../../i18n.js';
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';

export async function getStaticPaths() {
  const locales = Object.keys(I18N);
  return locales.map(lang => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
const t = I18N[lang];

// Fetch all posts for the current language
const allPosts = await getCollection('blog', ({ id }) => {
  return id.startsWith(`${lang}/`);
});

// Sort by date
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Get title based on lang
const blogTitle = lang === 'tr' ? 'SuppTime Blog' : 'SuppTime Blog';
const blogDesc = lang === 'tr' ? 'Sağlık, takviyeler ve bilimsel zamanlama hakkında en son yazılar.' : 'The latest articles on health, supplements, and scientific timing.';

const LANG_ORDER = ['en','tr','ko','ja','zh-cn','zh-tw','de','es','pt-br','it','nl','pl','ru','id','vi','th','ar'];

function shortCode(c) { 
  if (c === 'pt-br') return 'PT';
  if (c === 'zh-cn') return '简';
  if (c === 'zh-tw') return '繁';
  return c.toUpperCase(); 
}

---

<Layout title={`${blogTitle} - SuppTime`} description={blogDesc} lang={lang} dir={t.dir || 'ltr'}>
  <Navbar lang={lang} isBlog={true} />

  <main style="padding-top: 120px; min-height: 100vh; background: #fafafa;">
    <div style="max-width: 800px; margin: 0 auto; padding: 0 24px;">
      <h1 class="h2" style="margin-bottom: 16px;">{blogTitle}</h1>
      <p style="color: #666; font-size: 18px; margin-bottom: 48px;">{blogDesc}</p>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 32px;">
        {allPosts.map(post => (
          <article class="blog-card" style="background: white; border-radius: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease; display: flex; flex-direction: column;">
            <a href={`/${lang}/blog/${post.id.split('/').pop().replace('.md', '')}`} style="text-decoration: none; color: inherit; display: flex; flex-direction: column; flex-grow: 1;">
              {post.data.image && (
                <div style="width: 100%; height: 220px; overflow: hidden; background: #f4f6f8; position: relative;">
                  <img src={post.data.image} alt={post.data.title} style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;" class="blog-card-img" />
                </div>
              )}
              <div style="padding: 28px; display: flex; flex-direction: column; flex-grow: 1;">
                <h2 style="font-size: 22px; font-weight: 600; margin-bottom: 12px; line-height: 1.3;">{post.data.title}</h2>
                <p style="color: #666; line-height: 1.6; font-size: 16px; margin-bottom: 24px; flex-grow: 1;">{post.data.description}</p>
                <div style="font-size: 14px; color: #999; font-weight: 500;">
                  {post.data.pubDate.toLocaleDateString(lang)} • {post.data.author || 'SuppTime Team'}
                </div>
              </div>
            </a>
          </article>
        ))}
        
        {allPosts.length === 0 && (
          <p style="color: #999; font-style: italic; grid-column: 1 / -1;">No posts found for this language yet.</p>
        )}
      </div>
    </div>
  </main>
  
  <script>
    // Language Menu Toggling
    const langBtn = document.getElementById('lang-btn');
    const langMenu = document.getElementById('lang-menu');
    let langMenuOpen = false;
    
    if (langBtn && langMenu) {
      langBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        langMenuOpen = !langMenuOpen;
        langMenu.style.display = langMenuOpen ? 'grid' : 'none';
      });
      document.addEventListener('mousedown', (e) => {
        if (langMenuOpen && !langBtn.contains(e.target) && !langMenu.contains(e.target)) {
          langMenuOpen = false;
          langMenu.style.display = 'none';
        }
      });
    }
  </script>
</Layout>

<style is:global>
  .blog-card:hover {
    transform: translateY(-6px) scale(1.01);
    box-shadow: 0 16px 40px rgba(0,0,0,0.08) !important;
  }
  .blog-card:hover .blog-card-img {
    transform: scale(1.05);
  }
</style>
