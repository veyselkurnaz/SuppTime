---
import { getCollection } from 'astro:content';
import { I18N } from '../../../i18n.js';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const locales = Object.keys(I18N);
  return locales.map(lang => ({
    params: { lang },
  }));
}

const { lang } = Astro.params;
const t = I18N[lang];

// Fetch all posts for the current language
const allPosts = await getCollection('blog', ({ id }) => {
  return id.startsWith(`${lang}/`);
});

// Sort by date
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Get title based on lang
const blogTitle = lang === 'tr' ? 'SuppTime Blog' : 'SuppTime Blog';
const blogDesc = lang === 'tr' ? 'Sağlık, takviyeler ve bilimsel zamanlama hakkında en son yazılar.' : 'The latest articles on health, supplements, and scientific timing.';

const LANG_ORDER = ['en','tr','ko','ja','zh-cn','zh-tw','de','es','pt-br','it','nl','pl','ru','id','vi','th','ar'];

function shortCode(c) { 
  if (c === 'pt-br') return 'PT';
  if (c === 'zh-cn') return '简';
  if (c === 'zh-tw') return '繁';
  return c.toUpperCase(); 
}

---

<Layout title={`${blogTitle} - SuppTime`} description={blogDesc} lang={lang} dir={t.dir || 'ltr'}>
  <nav class="nav" id="nav" style="background: rgba(255,255,255,0.8); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(0,0,0,0.05);">
      <div class="nav-inner">
          <a href={`/${lang}/`} class="brand">
              <span class="brand-mark" style="width: 32px; height: 32px;">
                  <img src="/assets/watchos.png" alt="SuppTime" />
              </span>
              <span class="brand-name">SuppTime</span>
          </a>
          <div class="nav-links">
              <a href={`/${lang}/`}>{t.nav.home}</a>
              <a href={`/${lang}/blog/`}>{t.nav.blog}</a>
          </div>
          <div class="nav-tools">
              <div style="position: relative;" id="lang-switcher">
                  <button class="lang-btn" id="lang-btn" aria-label="Language">
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="10" />
                          <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                      </svg>
                      <span style="font-weight: 600" id="current-lang-code">{shortCode(lang)}</span>
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="m6 9 6 6 6-6" />
                      </svg>
                  </button>
                  <div class="lang-menu lang-menu-tall" id="lang-menu" style="display: none;">
                    {LANG_ORDER.map(code => {
                      const opt = I18N[code];
                      return (
                        <a href={`/${code}/blog/`} class={`lang-opt ${code === lang ? 'is-active' : ''}`} style="text-decoration:none; color:inherit;">
                          <span style="font-family: var(--mono); font-size: 11px; opacity: 0.5; width: 26px;">{shortCode(code)}</span>
                          <span>{opt.langName}</span>
                          {code === lang && (
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
                          )}
                        </a>
                      );
                    })}
                  </div>
              </div>
          </div>
      </div>
  </nav>

  <main style="padding-top: 120px; min-height: 100vh; background: #fafafa;">
    <div style="max-width: 800px; margin: 0 auto; padding: 0 24px;">
      <h1 class="h2" style="margin-bottom: 16px;">{blogTitle}</h1>
      <p style="color: #666; font-size: 18px; margin-bottom: 48px;">{blogDesc}</p>

      <div style="display: flex; flex-direction: column; gap: 32px;">
        {allPosts.map(post => (
          <article style="background: white; padding: 24px; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.03);">
            <a href={`/${lang}/blog/${post.id.split('/').pop().replace('.md', '')}`} style="text-decoration: none; color: inherit;">
              <h2 style="font-size: 24px; font-weight: 600; margin-bottom: 8px;">{post.data.title}</h2>
              <p style="color: #666; line-height: 1.6; margin-bottom: 16px;">{post.data.description}</p>
              <div style="font-size: 14px; color: #999;">
                {post.data.pubDate.toLocaleDateString(lang)} • {post.data.author}
              </div>
            </a>
          </article>
        ))}
        
        {allPosts.length === 0 && (
          <p style="color: #999; font-style: italic;">No posts found for this language yet.</p>
        )}
      </div>
    </div>
  </main>
  
  <script>
    // Language Menu Toggling
    const langBtn = document.getElementById('lang-btn');
    const langMenu = document.getElementById('lang-menu');
    let langMenuOpen = false;
    
    if (langBtn && langMenu) {
      langBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        langMenuOpen = !langMenuOpen;
        langMenu.style.display = langMenuOpen ? 'grid' : 'none';
      });
      document.addEventListener('mousedown', (e) => {
        if (langMenuOpen && !langBtn.contains(e.target) && !langMenu.contains(e.target)) {
          langMenuOpen = false;
          langMenu.style.display = 'none';
        }
      });
    }
  </script>
</Layout>
