---
import Layout from '../../layouts/Layout.astro';
import { I18N } from '../../i18n.js';
import legalData from '../../data/legal.json';

export function getStaticPaths() {
  return Object.keys(I18N).map((lang) => ({
    params: { lang }
  }));
}

const { lang } = Astro.params as { lang: string };
const t = (legalData[lang as keyof typeof legalData]?.terms || legalData['en'].terms) as any;
const dir = I18N[lang as keyof typeof I18N]?.dir || 'ltr';
---
<Layout title={`${t.title} - SuppTime`} description={t.title} lang={lang} dir={dir}>
  <main style="padding-top: 120px; padding-bottom: 80px; min-height: 100vh; background: #fafafa;">
    <article class="prose" style="max-width: 800px; margin: 0 auto; padding: 48px; background: white; border-radius: 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.03);" dir={dir}>
      <h1 style="font-size: 36px; font-weight: 700; margin-bottom: 8px;">{t.title}</h1>
      <p style="font-family: var(--mono); font-size: 13px; color: #666; margin-bottom: 40px;">{t.eff}</p>

      <p>{t.intro}</p>

      {t.sections.map((sec: any) => (
        <>
          <h3>{sec.t}</h3>
          <p>{sec.p}</p>
        </>
      ))}

      <div class="disclaimer-box">
          <strong>{t.disc_title}</strong>
          <p>{t.disc}</p>
      </div>

      <div style="margin-top: 40px; text-align: center;">
        <a href={`/${lang}`} style="display: inline-block; padding: 12px 24px; background: #eee; color: #333; text-decoration: none; border-radius: 99px; font-weight: 500;">{t.back}</a>
      </div>
    </article>
  </main>
</Layout>
<style is:global>
  .prose h3 { font-size: 18px; font-weight: 600; margin: 40px 0 16px; color: #111; }
  .prose p, .prose li { font-size: 16px; line-height: 1.6; color: #444; margin-bottom: 16px; }
  .prose ul { padding-left: 24px; margin-bottom: 16px; }
  .prose a { color: #10b981; text-decoration: none; font-weight: 500; }
  .prose a:hover { text-decoration: underline; }
  .disclaimer-box { margin-top: 48px; padding: 24px; border-radius: 16px; background: rgba(245, 158, 11, 0.1); border: 1px solid rgba(245, 158, 11, 0.2); }
  .disclaimer-box strong { display: block; color: #b45309; font-size: 14px; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px; }
  .disclaimer-box p { color: #92400e; margin: 0; font-size: 15px; }
  
  @media (max-width: 600px) {
    .prose { padding: 24px !important; margin: 0 16px; }
  }
</style>
