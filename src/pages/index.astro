---
export const prerender = false;

const SUPPORTED = ['en','tr','ko','ja','zh-cn','zh-tw','de','es','pt-br','it','nl','pl','ru','id','vi','th','ar'];

function pickLocale(acceptLanguage: string | null): string {
  if (!acceptLanguage) return 'en';

  const candidates = acceptLanguage
    .split(',')
    .map((part) => {
      const [tag, qPart] = part.trim().split(';q=');
      return { tag: tag.trim().toLowerCase(), q: qPart ? parseFloat(qPart) : 1 };
    })
    .sort((a, b) => b.q - a.q);

  for (const { tag } of candidates) {
    if (SUPPORTED.includes(tag)) return tag;

    const short = tag.split('-')[0];
    if (SUPPORTED.includes(short)) return short;
    if (tag === 'zh-hk') return 'zh-tw';
    if (tag.startsWith('zh')) return 'zh-cn';
    if (tag.startsWith('pt')) return 'pt-br';
  }

  return 'en';
}

return Astro.redirect(`/${pickLocale(Astro.request.headers.get('accept-language'))}/`, 302);
---
