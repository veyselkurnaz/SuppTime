---
import { I18N } from '../i18n.js';

export interface Props {
  title: string;
  description: string;
  lang: string;
  dir: string;
  image?: string;
  ogType?: string;
  alternateUrls?: Record<string, string>;
  pubDate?: Date;
  author?: string;
}

const { title, description, lang, dir, image = '/assets/supptime_og_banner.png', ogType = 'website', alternateUrls, pubDate, author } = Astro.props;

// Compute hreflang tags for SEO
const locales = Object.keys(I18N);
const t = I18N[lang as keyof typeof I18N] || I18N['en'];
---

<!DOCTYPE html>
<html lang={lang} dir={dir}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="msvalidate.01" content="2776D68A367824A8B2982576EF57C35B" />
    <meta name="yandex-verification" content="5a1419db9a364d76" />
    <meta name="naver-site-verification" content="5b915b3db1b232ef0b258bd1b1261326b39d314e" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- SEO: Canonical Tag -->
    <link rel="canonical" href={new URL(Astro.url.pathname, 'https://supptime.app').href} />
    
    <meta name="apple-itunes-app" content="app-id=6762088156" />
    
    <!-- OpenGraph / Social Media Meta Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={`https://supptime.app${image}`} />
    
    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://supptime.app${image}`} />

    <!-- Advanced SEO & Mobile UX -->
    {ogType === 'article' && pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
    {ogType === 'article' && author && <meta property="article:author" content={author} />}
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />

    <link rel="icon" type="image/png" href="/assets/watchos.png" />
    <link rel="apple-touch-icon" href="/assets/watchos.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&family=Pretendard:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
    
    <!-- SEO: Hreflang Tags -->
    {alternateUrls ? (
      <>
        <link rel="alternate" href={`https://supptime.app${alternateUrls['en'] || ''}`} hreflang="x-default" />
        {Object.entries(alternateUrls).map(([loc, path]) => (
          <link rel="alternate" href={`https://supptime.app${path}`} hreflang={loc === 'pt-br' ? 'pt-BR' : (loc === 'zh-cn' ? 'zh-CN' : (loc === 'zh-tw' ? 'zh-TW' : loc))} />
        ))}
      </>
    ) : (
      <>
        <link rel="alternate" href="https://supptime.app/" hreflang="x-default" />
        {locales.map((l) => (
          <link rel="alternate" href={`https://supptime.app/${l}/`} hreflang={l === 'pt-br' ? 'pt-BR' : (l === 'zh-cn' ? 'zh-CN' : (l === 'zh-tw' ? 'zh-TW' : l))} />
        ))}
      </>
    )}

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-0GC3N2F5V1"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      // GDPR Default: Denied
      let consentGranted = false;
      try {
        if (localStorage.getItem('cookie_consent') === 'granted') {
          consentGranted = true;
        }
      } catch(e) {}

      gtag('consent', 'default', {
        'analytics_storage': consentGranted ? 'granted' : 'denied'
      });
      
      gtag('config', 'G-0GC3N2F5V1');
    </script>
</head>
<body class={`lang-${lang}`}>
    <slot />

    <footer class="foot">
        <div class="foot-inner">
            <div class="foot-top">
                <div class="foot-brand">
                    <span class="brand-mark" style="width: 36px; height: 36px;">
                        <img src="/assets/watchos.png" alt="SuppTime" />
                    </span>
                    <div>
                        <div class="brand-name" style="font-size: 16px; font-weight: 600;">SuppTime</div>
                        <div class="foot-tag">{t.footer?.tag}</div>
                    </div>
                </div>
                
                <div class="foot-nav">
                    <div class="foot-links">
                      {t.footer?.links?.map((l: string, i: number) => (
                        <a href={i === 0 ? `/${lang}/privacy` : (i === 1 ? `/${lang}/terms` : (i === 2 ? 'mailto:veyselkurnaz@icloud.com' : '#'))}>{l}</a>
                      ))}
                    </div>
                </div>
            </div>

            <div class="foot-bottom">
                {t.medical_disclaimer && (
                  <div class="foot-disclaimer">
                    {t.medical_disclaimer}
                  </div>
                )}
                <div class="foot-copy">© 2026 SuppTime, Inc.</div>
            </div>
        </div>
    </footer>

    <div id="cookie-banner" class="cookie-banner" style="display: none;" dir={dir}>
      <div class="cookie-content">
        <p>{t.cookie_banner?.text}</p>
        <div class="cookie-buttons">
          <button id="btn-accept" class="btn btn-primary btn-sm">{t.cookie_banner?.accept}</button>
          <button id="btn-decline" class="btn btn-outline btn-sm">{t.cookie_banner?.decline}</button>
        </div>
      </div>
    </div>
    
    <script is:inline>
      try {
        if (!localStorage.getItem('cookie_consent')) {
          document.getElementById('cookie-banner').style.display = 'flex';
        }

        document.getElementById('btn-accept')?.addEventListener('click', () => {
          localStorage.setItem('cookie_consent', 'granted');
          document.getElementById('cookie-banner').style.display = 'none';
          if (typeof gtag === 'function') {
            gtag('consent', 'update', {
              'analytics_storage': 'granted'
            });
          }
        });

        document.getElementById('btn-decline')?.addEventListener('click', () => {
          localStorage.setItem('cookie_consent', 'denied');
          document.getElementById('cookie-banner').style.display = 'none';
        });
      } catch(e) {}
    </script>

    <style is:global>
      .cookie-banner {
        position: fixed;
        bottom: 24px;
        left: 24px;
        max-width: 360px;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(0, 0, 0, 0.08);
        box-shadow: 0 16px 40px rgba(0,0,0,0.12);
        border-radius: 20px;
        padding: 20px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 16px;
        font-family: var(--sans);
      }
      .cookie-banner[dir="rtl"] {
        left: auto;
        right: 24px;
      }
      .cookie-banner p {
        margin: 0;
        font-size: 13px;
        line-height: 1.5;
        color: #111;
        font-weight: 500;
      }
      .cookie-buttons {
        display: flex;
        gap: 8px;
      }
      .cookie-buttons button {
        flex: 1;
        cursor: pointer;
        font-size: 13px;
        padding: 8px 12px;
        border-radius: 99px;
        font-weight: 600;
      }
      .cookie-buttons .btn-primary {
        background: #000;
        color: #fff;
        border: none;
      }
      .cookie-buttons .btn-outline {
        background: transparent;
        border: 1px solid #ddd;
        color: #333;
      }
      .cookie-buttons .btn-outline:hover {
        background: #f5f5f5;
      }
      
      @media (max-width: 768px) {
        .cookie-banner {
          left: 16px;
          right: 16px;
          bottom: 16px;
          max-width: 100%;
        }
      }
    </style>
</body>
</html>
