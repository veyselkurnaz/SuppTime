---
import { I18N } from '../i18n.js';

export interface Props {
  title: string;
  description: string;
  lang: string;
  dir: string;
}

const { title, description, lang, dir } = Astro.props;

// Compute hreflang tags for SEO
const locales = Object.keys(I18N);
---

<!DOCTYPE html>
<html lang={lang} dir={dir}>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/assets/watchos.png" />
    <link rel="apple-touch-icon" href="/assets/watchos.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&family=Pretendard:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles.css" />
    
    <!-- SEO: Hreflang Tags -->
    <link rel="alternate" href={`https://supptime.app/`} hreflang="x-default" />
    {locales.map((l) => (
      <link rel="alternate" href={`https://supptime.app/${l}/`} hreflang={l === 'pt-br' ? 'pt-BR' : (l === 'zh-cn' ? 'zh-CN' : (l === 'zh-tw' ? 'zh-TW' : l))} />
    ))}

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18153774378"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-18153774378');

      function gtag_report_conversion(url) {
        if (typeof gtag === 'undefined') {
          window.location = url;
          return false;
        }
        var redirected = false;
        var redirectFn = function () {
          if (!redirected) {
            redirected = true;
            window.location = url;
          }
        };
        setTimeout(redirectFn, 200);
        gtag('event', 'conversion', {
          'send_to': 'AW-967371332/KBlVCK2j9qkcEMTUo80D',
          'event_callback': redirectFn
        });
        return false;
      }
    </script>
</head>
<body class={`lang-${lang}`}>
    <slot />
</body>
</html>
